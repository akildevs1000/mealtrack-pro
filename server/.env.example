DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/mealtrack-pro?schema=public"
PORT=5044
JWT_SECRET="generate-a-long-random-string-for-production"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000,http://localhost:5173,http://localhost:8080"

# --- CMS (Oracle HRMS) roster sync ---------------------------------------
# Pulls CMS_EMPLOYEE_MASTER from the customer's Oracle DB into CmsEmployee.
# Deploy on the whitelisted CMS Application Server (Oracle :1521 only accepts
# that host's IP). Set CMS_SYNC_ENABLED=1 to start the hourly sync.
CMS_SYNC_ENABLED=0

# These six map 1:1 to the CMS access document.
ORACLE_CMS_HOST=                       # DB HOST IP
ORACLE_CMS_PORT=1521                   # Listener Traffic Port
ORACLE_CMS_SID=hrms                    # Target Database Name (SID)
ORACLE_CMS_USER=CMS_USER               # Runtime Target Schema User
ORACLE_CMS_PASSWORD=                   # Authentication Secret
ORACLE_CMS_TABLE=CMS_EMPLOYEE_MASTER   # Master Integration Table

# --- Access-card photos (live from Oracle EMP_PHOTO) ------------------------
# The printable access card fetches employee photos live from a separate Oracle
# table. Discover the real schema first: `npx tsx scripts/probe-emp-photo.ts`
# (add `--emp <employeeNumber>` to test one fetch), then set these to match.
ORACLE_CMS_PHOTO_ENABLED=0             # 1 to serve card photos live from Oracle (after probing)
ORACLE_CMS_PHOTO_TABLE=EMP_PHOTO       # Photo table name
ORACLE_CMS_PHOTO_COL=PHOTO             # BLOB column holding the image bytes
ORACLE_CMS_PHOTO_EMPID_COL=EMP_ID      # Key column in EMP_PHOTO
ORACLE_CMS_PHOTO_KEY=laborId           # Which synced value keys it: laborId | laborCode
# ORACLE_CMS_PHOTO_QUERY=              # Optional full SELECT (one :id bind, alias -> PHOTO)
                                       #   e.g. join EMP_PHOTO to the master to resolve empid
# ORACLE_CMS_PHOTO_MIME=image/jpeg     # Fallback mime if the bytes can't be sniffed
# ORACLE_CMS_PHOTO_TIMEOUT_MS=30000    # Per-fetch Oracle call timeout
# Photos may live on a DIFFERENT Oracle instance than the roster. If so, point
# the photo fetch at that box (else it reuses the roster ORACLE_CMS_* connection):
# ORACLE_CMS_PHOTO_HOST=hrms.innovogroup.com
# ORACLE_CMS_PHOTO_PORT=1521
# ORACLE_CMS_PHOTO_SERVICE=            # service name (or ORACLE_CMS_PHOTO_SID=)
# ORACLE_CMS_PHOTO_USER=CMS_USER       # defaults to ORACLE_CMS_USER
# ORACLE_CMS_PHOTO_PASSWORD=           # defaults to ORACLE_CMS_PASSWORD
