// MealTrack Pro database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  operator
  user
  manager
}

enum UserStatus {
  Active
  Inactive
}

enum EmployeeStatus {
  Active
  Leave
  Vacation
  Inactive
}

enum CmsEmployeeStatus {
  Active
  InActive
  leave
}

enum MealEligibility {
  Y
  N
}

enum MealKind {
  Breakfast
  Lunch
  Dinner
}

enum ScanStatus {
  Eligible
  AlreadyServed
  NotEligible
  WrongCamp
  Expired
}

enum ManagerRole {
  CampManager
  SeniorManager
  Supervisor
}

enum ManagerShift {
  Morning
  Evening
  FullDay
}

enum ManagerStatus {
  Active
  Suspended
  Expired
}

model User {
  id               String     @id @default(cuid())
  name             String
  username         String     @unique
  email            String     @unique
  passwordHash     String
  role             Role
  status           UserStatus @default(Active)
  // Primary assigned camp (first of assignedCampCodes). Kept for back-compat
  // with readers that still expect a single code.
  assignedCampCode String?
  // Full set of camps a manager is scoped to. campScopeOf() uses this so a
  // supplier mapped to several camps sees all of them. Empty for non-managers.
  assignedCampCodes String[] @default([])
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([role])
}

model RolePermission {
  id     String @id @default(cuid())
  role   Role
  tab    String
  view   Boolean @default(false)
  edit   Boolean @default(false)
  delete Boolean @default(false)

  @@unique([role, tab])
  @@index([role])
}

model Camp {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "AD-01"
  name      String
  site      String
  employees Int      @default(0)
  online    Boolean  @default(true)
  // Meal windows stored as HH:mm strings
  breakfastStart String @default("05:30")
  breakfastEnd   String @default("08:30")
  lunchStart     String @default("11:30")
  lunchEnd       String @default("14:00")
  dinnerStart    String @default("18:30")
  dinnerEnd      String @default("21:30")

  devices   Device[]
  // Suppliers whose PRIMARY camp is this one (single-FK relation).
  managers  CampManager[] @relation("ManagerPrimaryCamp")
  // Suppliers assigned to this camp via the many-to-many set.
  multiManagers CampManager[] @relation("ManagerCamps")

  // Parent company (siblings: Camp, Project, Supplier all hang off a Company).
  companyCode String?
  companyRef  Company? @relation(fields: [companyCode], references: [code])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Contractor / employer companies. Parent of Camp / Project / Supplier.
model Company {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "INNOVO"
  name      String
  contact   String   @default("") // primary contact person
  email     String   @default("")
  phone     String   @default("")
  employees Int      @default(0)
  active    Boolean  @default(true)

  // Children (all siblings to each other, parented by this Company).
  camps       Camp[]
  projects    Project[]
  suppliers   CampManager[]
  estimations FoodEstimation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Construction projects / sites. Parented by a Company.
model Project {
  id        String   @id @default(cuid())
  code      String   @unique // e.g. "PRJ-01"
  name      String
  location  String   @default("") // site / area
  company   String   @default("") // owning company name (display)
  manager   String   @default("") // project manager / contact
  employees Int      @default(0)
  active    Boolean  @default(true)

  // Meal windows (HH:mm), same as Camp — a project is a physical scanning site.
  breakfastStart String @default("05:30")
  breakfastEnd   String @default("08:30")
  lunchStart     String @default("11:30")
  lunchEnd       String @default("14:00")
  dinnerStart    String @default("18:30")
  dinnerEnd      String @default("21:30")

  companyCode String?
  companyRef  Company? @relation(fields: [companyCode], references: [code])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Food estimation entry: estimated meal headcounts for a
// Company / Supplier / Project / Camp on a given date.
model FoodEstimation {
  id          String   @id @default(cuid())
  date        DateTime @default(now()) // the estimation date (records current date)
  companyCode String
  company     Company  @relation(fields: [companyCode], references: [code])
  supplierId  String? // CampManager id
  projectCode String?
  campCode    String?
  breakfast   Int      @default(0)
  lunch       Int      @default(0)
  dinner      Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyCode, date])
}

// CMS employee roster (different camp coding scheme: "CAMP 19")
model CmsEmployee {
  id              String             @id @default(cuid())
  company         String
  laborId         Int                @unique
  laborCode       String             @unique
  name            String
  designation     String
  grade           String?            // CMS GRADE column (nullable — not every row has one)
  doj             DateTime
  campCode        String             // e.g. "CAMP 19"
  campName        String
  mealsEligibility MealEligibility   @default(Y)
  status          CmsEmployeeStatus  @default(Active)
  effectiveDate   DateTime?
  lastUpdated     DateTime

  mealRecords     MealRecord[]

  @@index([campCode])
  @@index([status])
}

// Per-day meal record for a CMS employee
model MealRecord {
  id          String      @id @default(cuid())
  employee    CmsEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String
  date        DateTime    @db.Date
  breakfastTaken Boolean  @default(false)
  breakfastTime  String?  // HH:mm
  lunchTaken     Boolean  @default(false)
  lunchTime      String?
  dinnerTaken    Boolean  @default(false)
  dinnerTime     String?

  @@unique([employeeId, date])
  @@index([date])
}

// Scan events (live activity)
model Scan {
  id        String       @id @default(cuid())
  time      DateTime     @default(now())
  name      String       // labour name at time of scan
  labourId  String
  // Site code where the scan happened — a Camp.code OR a Project.code. Kept as a
  // plain string (no FK) so a project site can be recorded the same way a camp is.
  campCode  String
  meal      MealKind
  status    ScanStatus
  // Filled when the scan came from the Android scanner app, identifying
  // which camp manager was logged in. Null for legacy/admin-posted scans.
  manager   CampManager? @relation(fields: [managerId], references: [id])
  managerId String?

  @@index([time])
  @@index([campCode])
  @@index([status])
  @@index([managerId])
}

model Device {
  id             String   @id @default(cuid())
  name           String   @unique
  // A device is tied to either a camp OR a project (the register dialog merges
  // them into one "Location" picker). Both are nullable so either can be set.
  camp           Camp?    @relation(fields: [campCode], references: [code])
  campCode       String?
  projectCode    String?
  battery        Int      @default(100)
  online         Boolean  @default(true)
  lastSync       DateTime @default(now())
  macAddress     String
  serial         String   @unique
  model          String
  androidVersion String
  appVersion     String
  ipAddress      String
  assignedTo     String
  registeredOn   DateTime

  @@index([campCode])
}

model CampManager {
  id          String        @id @default(cuid())
  name        String
  username    String        @unique
  passwordHash String
  // Bcrypt hash of the numeric PIN this manager uses to log into the
  // Android scanner. Null when the manager cannot operate a scanner.
  pinHash      String?
  email       String        @unique
  phone       String
  emiratesId  String
  // Primary camp (first selected). Drives the scanner default + legacy readers.
  camp        Camp          @relation("ManagerPrimaryCamp", fields: [campCode], references: [code])
  campCode    String
  // Full set of camps this supplier is assigned to (many-to-many). Always
  // includes campCode. The implicit join table is `_ManagerCamps`.
  camps       Camp[]        @relation("ManagerCamps")
  // Parent company (a Supplier belongs to a Company).
  companyCode String?
  companyRef  Company?      @relation(fields: [companyCode], references: [code])
  role        ManagerRole
  shift       ManagerShift
  joinDate    DateTime
  expiryDate  DateTime
  status      ManagerStatus @default(Active)
  lastLoginAt DateTime?
  avatar      String?
  permBreakfast Boolean @default(true)
  permLunch     Boolean @default(true)
  permDinner    Boolean @default(true)
  permReports   Boolean @default(true)

  scans Scan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campCode])
}

// Audit log (used by /audit route)
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actorId   String?
  actor     String?
  action    String
  target    String?
  details   String?

  @@index([at])
}

// Singleton FTP config used by scheduled FTP delivery. Only one row is expected
// at a time; the API upserts to id="default". Password is stored plaintext —
// see README for the encryption-at-rest TODO.
model FtpConfig {
  id         String   @id @default("default")
  host       String
  port       Int      @default(21)
  user       String
  password   String
  remotePath String   @default("/")
  secure     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Singleton SMTP config used by scheduled email delivery. Same singleton
// pattern as FtpConfig; password stored plaintext (encryption-at-rest TODO).
model MailConfig {
  id        String   @id @default("default")
  host      String
  port      Int      @default(587)
  username  String
  password  String
  // true for implicit TLS (port 465); false uses STARTTLS (port 587).
  secure    Boolean  @default(false)
  fromName  String   @default("MyMeal")
  fromEmail String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ScheduleFrequency {
  daily
  weekly
  monthly
}

enum ScheduleReportType {
  consumption
  employee
  scans
  camp
  wastage
  // Integrated Reports Suite (the 5 new reports).
  dailyTransaction
  bySupplier
  byLocation
  requestComparison
  duplicateEligibility
}

enum ScheduleFormat {
  pdf
  excel
  both
}

enum ScheduleDestination {
  email
  ftp
}

enum ScheduleRunStatus {
  success
  failed
}

model Schedule {
  id            String              @id @default(cuid())
  name          String
  enabled       Boolean             @default(false)
  reportType    ScheduleReportType
  format        ScheduleFormat
  frequency     ScheduleFrequency
  // "HH:MM" — interpreted in the server's local timezone.
  time          String
  // 0 = Sun .. 6 = Sat (weekly only)
  weekday       Int?
  // 1..28 (monthly only)
  dayOfMonth    Int?
  destination   ScheduleDestination @default(email)
  // Legacy: app-user IDs. Kept for back-compat; the UI now writes
  // recipientEmails directly so arbitrary addresses can be added.
  recipientIds  String[]            @default([])
  // Email addresses the report is sent to when destination = email.
  recipientEmails String[]          @default([])
  // Used by the cron worker to avoid re-firing within the same minute and to
  // skip schedules whose next slot is in the future.
  nextRunAt     DateTime?
  lastRunAt     DateTime?
  lastRunStatus ScheduleRunStatus?
  lastRunDetail String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([enabled, nextRunAt])
}
